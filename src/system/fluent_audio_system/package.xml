  <test_depend>fa_interfaces</test_depend>
  <test_depend>fa_kws</test_depend>
  <test_depend>fa_mix</test_depend>
  <test_depend>fa_out</test_depend>
  <test_depend>fa_resample</test_depend>
  <test_depend>fa_sample_format</test_depend>
  <test_depend>fa_tts</test_depend>
  <test_depend>fa_turn_detector</test_depend>

