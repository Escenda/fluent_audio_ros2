<?xml version="1.0"?>
<package format="3">
  <name>fluent_audio_system</name>
  <version>0.1.0</version>
  <description>YAML-driven launch package for FluentAudio node groups.</description>

  <maintainer email="maintainer@example.com">FluentAudio</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <exec_depend>ament_index_python</exec_depend>
  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>
  <exec_depend>python3-pydantic</exec_depend>
  <exec_depend>python3-yaml</exec_depend>

  <test_depend>python3-pytest</test_depend>
  <test_depend>fa_file_in</test_depend>
  <test_depend>fa_file_out</test_depend>
  <test_depend>fa_network_in</test_depend>
  <test_depend>fa_network_out</test_depend>
  <test_depend>fa_interfaces</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
