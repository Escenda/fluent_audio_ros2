<?xml version="1.0"?>
<package format="3">
  <name>fluent_audio_system</name>
  <version>0.1.0</version>
  <description>YAML-driven launch package for FluentAudio node groups.</description>

  <maintainer email="maintainer@example.com">FluentAudio</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <exec_depend>ament_index_python</exec_depend>
  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>
  <exec_depend>python3-pydantic</exec_depend>
  <exec_depend>python3-yaml</exec_depend>
  <exec_depend>fa_audio_mcp</exec_depend>
  <exec_depend>fa_audio_window</exec_depend>
  <exec_depend>fa_dc_offset_removal</exec_depend>
  <exec_depend>fa_dialogue</exec_depend>
  <exec_depend>fa_high_pass</exec_depend>
  <exec_depend>fa_in</exec_depend>
  <exec_depend>fa_interfaces</exec_depend>
  <exec_depend>fa_kws</exec_depend>
  <exec_depend>fa_mix</exec_depend>
  <exec_depend>fa_out</exec_depend>
  <exec_depend>fa_resample</exec_depend>
  <exec_depend>fa_sample_format</exec_depend>
  <exec_depend>fa_tts</exec_depend>
  <exec_depend>fa_turn_detector</exec_depend>

  <test_depend>python3-pytest</test_depend>
  <test_depend>rclpy</test_depend>
  <test_depend>rosgraph_msgs</test_depend>
  <test_depend>ros2launch</test_depend>
  <test_depend>fa_audio_mcp</test_depend>
