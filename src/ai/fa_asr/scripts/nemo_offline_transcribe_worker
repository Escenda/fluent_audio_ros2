#!/usr/bin/env python3
from __future__ import annotations

import argparse
from contextlib import redirect_stdout
import importlib
import importlib.util
import inspect
import json
import math
import os
import struct
import sys
import tempfile
import wave
from pathlib import Path


SUPPORTED_CHANNELS = 1
SUPPORTED_RESULT_FORMATS = frozenset(("plain_text", "segments_json_v1"))
INT16_MAX = 32767
INT16_MIN = -32768


class WorkerError(RuntimeError):
    pass


def main() -> int:
    parser = _build_parser()
    args = parser.parse_args()
    try:
        if args.command == "health":
            _run_health(args)
            print("ok")
            return 0
        if args.command == "transcribe":
            _run_transcribe(args)
            return 0
        raise WorkerError(f"unsupported command: {args.command}")
    except WorkerError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except Exception as exc:
        print(
            f"nemo_offline_transcribe_worker failed: {exc.__class__.__name__}: {exc}",
            file=sys.stderr,
        )
        return 1


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser()
    subparsers = parser.add_subparsers(dest="command", required=True)

    health = subparsers.add_parser("health")
    health.add_argument("--model", required=True)
    health.add_argument("--language", required=True)
    health.add_argument("--sample-rate", required=True, type=int)
    health.add_argument("--channels", required=True, type=int)

    transcribe = subparsers.add_parser("transcribe")
    transcribe.add_argument("--audio", required=True)
    transcribe.add_argument("--model", required=True)
    transcribe.add_argument("--sample-rate", required=True, type=int)
    transcribe.add_argument("--channels", required=True, type=int)
    transcribe.add_argument("--language", required=True)
    transcribe.add_argument("--result-format", required=True)
    transcribe.add_argument("--output", default="")
    return parser


def _run_health(args: argparse.Namespace) -> None:
    config = _config_from_args(args)
    with redirect_stdout(sys.stderr):
        model = _load_nemo_model(config.model_path)
        _validate_model_for_offline_transcribe(model, config)


def _run_transcribe(args: argparse.Namespace) -> None:
    config = _config_from_args(args)
    audio_path = _require_readable_file(args.audio, "audio")
    samples = _read_float32le_mono_samples(audio_path)
    with redirect_stdout(sys.stderr):
        model = _load_nemo_model(config.model_path)
        _validate_model_for_offline_transcribe(model, config)
        transcript = _transcribe_samples(model, samples=samples, config=config)
    _emit_transcript(
        transcript,
        result_format=config.result_format,
        sample_count=len(samples),
        output_value=args.output,
    )


class WorkerConfig:
    def __init__(
        self,
        *,
        model_path: Path,
        language: str,
        sample_rate_hz: int,
        channels: int,
        result_format: str,
    ) -> None:
        self.model_path = model_path
        self.language = language
        self.sample_rate_hz = sample_rate_hz
        self.channels = channels
        self.result_format = result_format


def _config_from_args(args: argparse.Namespace) -> WorkerConfig:
    language = args.language.strip()
    if not language:
        raise WorkerError("language is required")
    if type(args.sample_rate) is not int or args.sample_rate <= 0:
        raise WorkerError("sample_rate must be a positive integer")
    if type(args.channels) is not int or args.channels != SUPPORTED_CHANNELS:
        raise WorkerError("channels must be 1; upstream must provide mono audio")
    result_format = getattr(args, "result_format", "plain_text")
    if result_format not in SUPPORTED_RESULT_FORMATS:
        raise WorkerError(f"result_format is unsupported: {result_format}")
    return WorkerConfig(
        model_path=_require_readable_file(args.model, "model"),
        language=language,
        sample_rate_hz=args.sample_rate,
        channels=args.channels,
        result_format=result_format,
    )


def _require_readable_file(value: str, label: str) -> Path:
    path = Path(value).expanduser()
    try:
        resolved = path.resolve(strict=True)
    except FileNotFoundError as exc:
        raise WorkerError(f"{label} file does not exist: {path}") from exc
    if not resolved.is_file():
        raise WorkerError(f"{label} path is not a file: {resolved}")
    if not os.access(resolved, os.R_OK):
        raise WorkerError(f"{label} file is not readable: {resolved}")
    return resolved


def _read_float32le_mono_samples(path: Path) -> tuple[float, ...]:
    raw_audio = path.read_bytes()
    if not raw_audio:
        raise WorkerError("audio file is empty")
    if len(raw_audio) % 4 != 0:
        raise WorkerError("audio must be raw float32le mono; byte length is not divisible by 4")
    samples: list[float] = []
    for index, (sample,) in enumerate(struct.iter_unpack("<f", raw_audio)):
        if not math.isfinite(sample):
            raise WorkerError(f"audio sample {index} is not finite")
        if sample < -1.0 or sample > 1.0:
            raise WorkerError(f"audio sample {index} is outside normalized [-1.0, 1.0] range")
        samples.append(sample)
    if not samples:
        raise WorkerError("audio contains no float32le samples")
    return tuple(samples)


def _load_nemo_model(model_path: Path):
    for module_name in (
        "nemo",
        "nemo.collections",
        "nemo.collections.asr",
        "nemo.collections.asr.models",
    ):
        if importlib.util.find_spec(module_name) is None:
            raise WorkerError("NeMo ASR module is unavailable in this worker environment")
    models_module = importlib.import_module("nemo.collections.asr.models")
    if not hasattr(models_module, "ASRModel"):
        raise WorkerError("NeMo ASRModel is unavailable")
    asr_model_class = models_module.ASRModel
    if not hasattr(asr_model_class, "restore_from"):
        raise WorkerError("NeMo ASRModel.restore_from is unavailable")
    model = asr_model_class.restore_from(str(model_path))
    if not hasattr(model, "eval"):
        raise WorkerError("NeMo model does not expose eval")
    model.eval()
    return model


def _validate_model_for_offline_transcribe(model, config: WorkerConfig) -> None:
    if not hasattr(model, "transcribe"):
        raise WorkerError("NeMo model does not expose offline transcribe")
    model_sample_rate = _model_sample_rate_hz(model)
    if model_sample_rate > 0 and model_sample_rate != config.sample_rate_hz:
        raise WorkerError(
            f"model sample_rate {model_sample_rate} does not match configured "
            f"{config.sample_rate_hz}"
        )
    languages = _model_languages(model)
    if languages and config.language not in languages:
        raise WorkerError(f"language {config.language} is not supported by model")


def _model_sample_rate_hz(model) -> int:
    cfg = _optional_attr(model, "cfg")
    if cfg is None:
        return 0
    preprocessor = _optional_config_section(cfg, "preprocessor")
    if preprocessor is None:
        return 0
    value = _optional_config_section(preprocessor, "sample_rate")
    if type(value) is int and value > 0:
        return value
    return 0


def _model_languages(model) -> tuple[str, ...]:
    cfg = _optional_attr(model, "cfg")
    if cfg is None:
        return ()
    for key in ("languages", "supported_languages", "lang_ids"):
        value = _optional_config_section(cfg, key)
        languages = _string_tuple(value)
        if languages:
            return languages
    tokenizer = _optional_attr(model, "tokenizer")
    if tokenizer is not None:
        for key in ("langs", "languages", "supported_languages"):
            value = _optional_attr(tokenizer, key)
            languages = _string_tuple(value)
            if languages:
                return languages
    return ()


def _transcribe_samples(
    model,
    *,
    samples: tuple[float, ...],
    config: WorkerConfig,
) -> str:
    with tempfile.TemporaryDirectory(prefix="fa_asr_nemo_offline_") as tmpdir:
        wav_path = Path(tmpdir) / "input.wav"
        _write_pcm16_mono_wav(wav_path, samples=samples, sample_rate_hz=config.sample_rate_hz)
        kwargs = _transcribe_kwargs(model, config)
        result = model.transcribe([str(wav_path)], **kwargs)
    transcript = _extract_transcript_text(result)
    if not transcript:
        raise WorkerError("NeMo offline transcribe returned an empty transcript")
    return transcript


def _transcribe_kwargs(model, config: WorkerConfig):
    kwargs = {
        "batch_size": 1,
        "return_hypotheses": False,
        "verbose": False,
    }
    try:
        signature = inspect.signature(model.transcribe)
    except (TypeError, ValueError):
        return kwargs
    supported_parameters = set(signature.parameters.keys())
    return {
        key: value
        for key, value in kwargs.items()
        if key in supported_parameters
    } | _language_kwargs(supported_parameters, config.language)


def _language_kwargs(supported_parameters: set[str], language: str) -> dict[str, str]:
    for key in ("language", "language_id", "source_lang", "source_language"):
        if key in supported_parameters:
            return {key: language}
    return {}


def _extract_transcript_text(result) -> str:
    if type(result) is str:
        return result.strip()
    if type(result) is list or type(result) is tuple:
        if len(result) != 1:
            raise WorkerError("NeMo transcribe must return exactly one transcript")
        return _extract_transcript_text(result[0])
    text_value = _optional_attr(result, "text")
    if type(text_value) is str:
        return text_value.strip()
    raise WorkerError("NeMo transcribe returned an unsupported result shape")


def _write_pcm16_mono_wav(
    path: Path,
    *,
    samples: tuple[float, ...],
    sample_rate_hz: int,
) -> None:
    # fa_asr passes raw normalized float32le mono. This worker is the explicit
    # backend adapter that creates a temporary WAV for NeMo's offline API.
    with wave.open(str(path), "wb") as wav_file:
        wav_file.setnchannels(1)
        wav_file.setsampwidth(2)
        wav_file.setframerate(sample_rate_hz)
        wav_file.writeframes(_float_samples_to_pcm16(samples))


def _float_samples_to_pcm16(samples: tuple[float, ...]) -> bytes:
    pcm16 = bytearray()
    for sample in samples:
        if sample <= -1.0:
            pcm16.extend(struct.pack("<h", INT16_MIN))
            continue
        if sample >= 1.0:
            pcm16.extend(struct.pack("<h", INT16_MAX))
            continue
        pcm16.extend(struct.pack("<h", int(round(sample * INT16_MAX))))
    return bytes(pcm16)


def _emit_transcript(
    transcript: str,
    *,
    result_format: str,
    sample_count: int,
    output_value: str,
) -> None:
    if result_format == "plain_text":
        payload = transcript
    elif result_format == "segments_json_v1":
        payload = json.dumps(
            {
                "result_format": "segments_json_v1",
                "segments": [
                    {
                        "start_sample": 0,
                        "end_sample": sample_count,
                        "text": transcript,
                    }
                ],
            },
            ensure_ascii=False,
            separators=(",", ":"),
        )
    else:
        raise WorkerError(f"result_format is unsupported: {result_format}")

    if output_value:
        output_path = Path(output_value).expanduser()
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(payload + "\n", encoding="utf-8")
        return
    print(payload)


def _optional_attr(value, name: str):
    if not hasattr(value, name):
        return None
    return getattr(value, name)


def _optional_config_section(config, name: str):
    if isinstance(config, dict):
        return config.get(name)
    return _optional_attr(config, name)


def _string_tuple(value) -> tuple[str, ...]:
    if type(value) is str:
        return (value,)
    if type(value) is list or type(value) is tuple:
        strings: list[str] = []
        for item in value:
            if type(item) is str and item.strip():
                strings.append(item)
        return tuple(strings)
    return ()


if __name__ == "__main__":
    raise SystemExit(main())
