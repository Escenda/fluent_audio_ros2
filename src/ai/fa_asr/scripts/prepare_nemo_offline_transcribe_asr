#!/usr/bin/env bash
set -euo pipefail

SUPPORTED_MODEL_ID="parakeet-1.1b-multilingual-offline"
SUPPORTED_ARTIFACT="nvidia/riva/parakeet-rnnt-riva-1-1b-unified-ml-cs-universal:trainable_v1.0"
MODEL_FILE="Parakeet-RNNT-XXL-1.1b_merged_universal_spe8.5k_1.0.nemo"

SCRIPT_PATH="${BASH_SOURCE[0]}"
case "${SCRIPT_PATH}" in
  */*) SCRIPT_DIR="$(cd -- "${SCRIPT_PATH%/*}" >/dev/null 2>&1 && pwd -P)" ;;
  *) SCRIPT_DIR="$(pwd -P)" ;;
esac
PACKAGE_DIR="$(cd -- "${SCRIPT_DIR}/.." >/dev/null 2>&1 && pwd -P)"
WORKER="${SCRIPT_DIR}/nemo_offline_transcribe_worker"
MODEL_ID="${SUPPORTED_MODEL_ID}"
ARTIFACT="${SUPPORTED_ARTIFACT}"
MODELS_DIR="${PACKAGE_DIR}/models/nemo_offline_transcribe"
TRACE_FILE=""
TRACE_STATUS="failure"
TRACE_FAILURE_REASON=""
TRACE_FINALIZED=false

usage() {
  cat >&2 <<EOF
Usage: $(basename -- "$0") [options]

Options:
  --model-id MODEL_ID      supported model id (default: ${SUPPORTED_MODEL_ID})
  --artifact ARTIFACT      supported NGC artifact (default: ${SUPPORTED_ARTIFACT})
  --models-dir DIR         model directory (default: ${MODELS_DIR})
  --trace-file PATH        trace log file path
  -h, --help               show this help
EOF
}

trace_timestamp() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

trace_value() {
  local value="$1"
  value="${value//$'\r'/\\r}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\t'/\\t}"
  printf '%s' "${value}"
}

trace_append_line() {
  [[ -n "${TRACE_FILE}" ]] || return 0
  if ! printf '%s\n' "$1" >> "${TRACE_FILE}"; then
    printf 'ERROR: failed to write trace file: %s\n' "${TRACE_FILE}" >&2
    exit 1
  fi
}

trace_write_field() {
  local key="$1"
  local value="$2"
  trace_append_line "${key}=$(trace_value "${value}")"
}

trace_has_failure_reason() {
  [[ -n "${TRACE_FILE}" && -f "${TRACE_FILE}" ]] || return 1
  local line=""
  while IFS= read -r line; do
    case "${line}" in
      failure_reason=?*) return 0 ;;
    esac
  done < "${TRACE_FILE}"
  return 1
}

finalize_trace() {
  if [[ "${TRACE_FINALIZED}" == true ]]; then
    return 0
  fi
  TRACE_FINALIZED=true
  if [[ "${TRACE_STATUS}" != "success" && -z "${TRACE_FAILURE_REASON}" ]]; then
    TRACE_FAILURE_REASON="interrupted"
    trace_write_field "failure_reason" "${TRACE_FAILURE_REASON}"
  fi
  trace_write_field "status" "${TRACE_STATUS}"
  trace_write_field "ended_at" "$(trace_timestamp)"
}

on_exit() {
  local status=$?
  if [[ ${status} -ne 0 && "${TRACE_STATUS}" == "failure" && ! trace_has_failure_reason ]]; then
    TRACE_FAILURE_REASON="command exited with status ${status}"
    trace_write_field "failure_reason" "${TRACE_FAILURE_REASON}"
  fi
  finalize_trace
}

trap on_exit EXIT

fail() {
  local reason="$1"
  local code="${2:-1}"
  TRACE_FAILURE_REASON="${reason}"
  trace_write_field "failure_reason" "${reason}"
  printf 'ERROR: %s\n' "${reason}" >&2
  exit "${code}"
}

require_command() {
  local name="$1"
  if ! command -v -- "${name}" >/dev/null 2>&1; then
    fail "${name} is required to download ${ARTIFACT}, but it was not found in PATH"
  fi
}

absolute_existing_file() {
  local path="$1"
  local label="$2"
  if [[ ! -f "${path}" ]]; then
    fail "${label} does not exist or is not a file: ${path}"
  fi
  local dir="${path%/*}"
  local base="${path##*/}"
  if [[ "${dir}" == "${path}" ]]; then
    dir="."
  fi
  printf '%s/%s\n' "$(cd -- "${dir}" >/dev/null 2>&1 && pwd -P)" "${base}"
}

absolute_executable_file() {
  local path="$1"
  local label="$2"
  if [[ ! -f "${path}" ]]; then
    fail "${label} does not exist or is not a file: ${path}"
  fi
  if [[ ! -x "${path}" ]]; then
    fail "${label} is not executable: ${path}"
  fi
  absolute_existing_file "${path}" "${label}"
}

find_fluent_audio_root() {
  local current="${PACKAGE_DIR}"
  while [[ "${current}" != "/" ]]; do
    if [[ -f "${current}/PRODUCT_OWNER_ROLE.md" && -d "${current}/src/ai/fa_asr" ]]; then
      printf '%s\n' "${current}"
      return 0
    fi
    current="$(cd -- "${current}/.." >/dev/null 2>&1 && pwd -P)"
  done
  return 1
}

container_path_for() {
  local source_root="$1"
  local host_path="$2"
  case "${host_path}" in
    "${source_root}")
      printf '%s\n' "/ros2_ws/src/fluent_audio_ros2"
      ;;
    "${source_root}"/*)
      printf '%s/%s\n' "/ros2_ws/src/fluent_audio_ros2" "${host_path#"${source_root}/"}"
      ;;
    *)
      return 1
      ;;
  esac
}

shell_value() {
  printf '%q' "$1"
}

validate_supported_model() {
  if [[ "${MODEL_ID}" != "${SUPPORTED_MODEL_ID}" ]]; then
    fail "unsupported model id: ${MODEL_ID}"
  fi
  if [[ "${ARTIFACT}" != "${SUPPORTED_ARTIFACT}" ]]; then
    fail "unsupported artifact: ${ARTIFACT}"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --model-id)
        [[ $# -ge 2 ]] || fail "--model-id requires a value"
        MODEL_ID="$2"
        shift 2
        ;;
      --artifact)
        [[ $# -ge 2 ]] || fail "--artifact requires a value"
        ARTIFACT="$2"
        shift 2
        ;;
      --models-dir)
        [[ $# -ge 2 ]] || fail "--models-dir requires a value"
        MODELS_DIR="$2"
        shift 2
        ;;
      --trace-file)
        [[ $# -ge 2 ]] || fail "--trace-file requires a value"
        TRACE_FILE="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        fail "unknown argument: $1"
        ;;
    esac
  done
}

default_trace_file() {
  local trace_dir="${PACKAGE_DIR}/traces/prepare_nemo_offline_transcribe_asr"
  mkdir -p "${trace_dir}"
  printf '%s/prepare_%s_%s.log\n' \
    "${trace_dir}" \
    "$(date -u '+%Y%m%dT%H%M%SZ')" \
    "$$"
}

find_downloaded_model() {
  local download_dir="$1"
  local found=""
  while IFS= read -r -d '' candidate; do
    found="${candidate}"
    break
  done < <(find "${download_dir}" -type f -name "${MODEL_FILE}" -print0)
  if [[ -z "${found}" ]]; then
    fail "NGC artifact did not produce expected .nemo file: ${MODEL_FILE}"
  fi
  printf '%s\n' "${found}"
}

download_model() {
  local model_path="$1"
  if [[ -f "${model_path}" ]]; then
    trace_write_field "download" "skipped_existing_model"
    return 0
  fi

  require_command ngc
  mkdir -p "${MODELS_DIR}"
  local download_dir="${MODELS_DIR}/.ngc_download_${MODEL_ID}_$$"
  rm -rf "${download_dir}"
  mkdir -p "${download_dir}"
  trace_write_field "download_artifact" "${ARTIFACT}"
  if ! ngc registry model download-version "${ARTIFACT}" --dest "${download_dir}" >&2; then
    rm -rf "${download_dir}"
    fail "failed to download NGC artifact: ${ARTIFACT}"
  fi

  local downloaded_model
  downloaded_model="$(find_downloaded_model "${download_dir}")"
  mv "${downloaded_model}" "${model_path}"
  rm -rf "${download_dir}"
}

print_env_block() {
  local model_path="$1"
  local worker_path="$2"
  local source_root=""
  local container_model=""
  local container_worker=""
  local container_trace=""

  if source_root="$(find_fluent_audio_root)"; then
    container_model="$(container_path_for "${source_root}" "${model_path}" || true)"
    container_worker="$(container_path_for "${source_root}" "${worker_path}" || true)"
    container_trace="$(container_path_for "${source_root}" "${TRACE_FILE}" || true)"
  fi

  cat <<EOF
# Generated by prepare_nemo_offline_transcribe_asr for model_id=${MODEL_ID}
# Source normally for host paths. Source with FLUENT_AUDIO_ENV_TARGET=vlabor for /ros2_ws paths.
case "\${FLUENT_AUDIO_ENV_TARGET:-host}" in
  host)
    export FLUENT_AUDIO_ASR_BACKEND=nemo_offline_transcribe
    export FLUENT_AUDIO_NEMO_OFFLINE_TRANSCRIBE_MODEL_PATH=$(shell_value "${model_path}")
    export FLUENT_AUDIO_NEMO_OFFLINE_TRANSCRIBE_WORKER=$(shell_value "${worker_path}")
    export FLUENT_AUDIO_ASR_MODEL_PATH=$(shell_value "${model_path}")
    export FLUENT_AUDIO_ASR_WORKER=$(shell_value "${worker_path}")
    export FLUENT_AUDIO_ASR_PREPARE_TRACE_FILE=$(shell_value "${TRACE_FILE}")
    ;;
  vlabor)
    export FLUENT_AUDIO_ASR_BACKEND=nemo_offline_transcribe
    export FLUENT_AUDIO_NEMO_OFFLINE_TRANSCRIBE_MODEL_PATH=$(shell_value "${container_model:-${model_path}}")
    export FLUENT_AUDIO_NEMO_OFFLINE_TRANSCRIBE_WORKER=$(shell_value "${container_worker:-${worker_path}}")
    export FLUENT_AUDIO_ASR_MODEL_PATH=$(shell_value "${container_model:-${model_path}}")
    export FLUENT_AUDIO_ASR_WORKER=$(shell_value "${container_worker:-${worker_path}}")
    export FLUENT_AUDIO_ASR_PREPARE_TRACE_FILE=$(shell_value "${container_trace:-${TRACE_FILE}}")
    ;;
  *)
    printf %s\\n "unsupported FLUENT_AUDIO_ENV_TARGET: \${FLUENT_AUDIO_ENV_TARGET}" >&2
    return 2 2>/dev/null || exit 2
    ;;
esac
EOF
}

main() {
  parse_args "$@"
  if [[ -z "${TRACE_FILE}" ]]; then
    TRACE_FILE="$(default_trace_file)"
  else
    mkdir -p "$(dirname -- "${TRACE_FILE}")"
  fi
  : > "${TRACE_FILE}"
  trace_write_field "started_at" "$(trace_timestamp)"
  trace_write_field "model_id" "${MODEL_ID}"
  trace_write_field "artifact" "${ARTIFACT}"
  validate_supported_model

  local worker_path
  worker_path="$(absolute_executable_file "${WORKER}" "nemo_offline_transcribe_worker")"
  local model_path="${MODELS_DIR}/${MODEL_FILE}"
  download_model "${model_path}"
  model_path="$(absolute_existing_file "${model_path}" "nemo_offline_transcribe model")"
  trace_write_field "model_path" "${model_path}"
  trace_write_field "worker_path" "${worker_path}"

  TRACE_STATUS="success"
  printf 'Trace file: %s\n' "${TRACE_FILE}" >&2
  print_env_block "${model_path}" "${worker_path}"
}

main "$@"
