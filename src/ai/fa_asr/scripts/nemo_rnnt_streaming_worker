#!/usr/bin/env python3
from __future__ import annotations

import base64
import binascii
from contextlib import redirect_stdout
import importlib
import importlib.util
import json
import math
import os
import struct
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import TextIO, TypeAlias


JsonValue: TypeAlias = (
    str | int | float | bool | None | list["JsonValue"] | dict[str, "JsonValue"]
)
JsonMapping: TypeAlias = dict[str, JsonValue]

SUPPORTED_AUDIO_ENCODING = "FLOAT32LE"
WIRE_AUDIO_ENCODING = "base64_float32le"
SUPPORTED_CHANNELS = 1
TRACE_FILE_ENV = "FLUENT_AUDIO_NEMO_RNNT_WORKER_TRACE_FILE"
TRACE_STDERR_ENV = "FLUENT_AUDIO_NEMO_RNNT_WORKER_TRACE_STDERR"
DEFAULT_FINITE_ATTENTION_CONTEXT = (70, 1)


class WorkerError(RuntimeError):
    pass


class WorkerTrace:
    def __init__(self, trace_file: TextIO | None, *, stderr_enabled: bool) -> None:
        self._trace_file = trace_file
        self._stderr_enabled = stderr_enabled

    @classmethod
    def disabled(cls) -> "WorkerTrace":
        return cls(None, stderr_enabled=False)

    @classmethod
    def from_environment(cls) -> "WorkerTrace":
        trace_path_value = os.environ.get(TRACE_FILE_ENV, "").strip()
        stderr_enabled = _environment_bool(TRACE_STDERR_ENV)
        trace_file: TextIO | None = None
        if trace_path_value:
            trace_path = Path(trace_path_value).expanduser()
            try:
                trace_file = trace_path.open("a", encoding="utf-8", buffering=1)
            except OSError as exc:
                raise WorkerError(
                    f"{TRACE_FILE_ENV} is not writable: {trace_path}"
                ) from exc
        return cls(trace_file, stderr_enabled=stderr_enabled)

    def close(self) -> None:
        if self._trace_file is not None:
            self._trace_file.close()
            self._trace_file = None

    def emit(
        self,
        event: str,
        *,
        command: str = "",
        session_id: str = "",
        sample_count: int = 0,
        accepted_sample_count: int = 0,
        chunk_count: int = 0,
        step_num: int = 0,
        duration_ms: float = -1.0,
        text_length: int = -1,
        error_type: str = "",
        error_message: str = "",
        details: JsonMapping | None = None,
    ) -> None:
        if self._trace_file is None and not self._stderr_enabled:
            return
        record: JsonMapping = {
            "event": event,
            "pid": os.getpid(),
            "unix_ns": time.time_ns(),
        }
        if command:
            record["command"] = command
        if session_id:
            record["session_id"] = session_id
        if sample_count:
            record["sample_count"] = sample_count
        if accepted_sample_count:
            record["accepted_sample_count"] = accepted_sample_count
        if chunk_count:
            record["chunk_count"] = chunk_count
        if step_num:
            record["step_num"] = step_num
        if duration_ms >= 0.0:
            record["duration_ms"] = round(duration_ms, 6)
        if text_length >= 0:
            record["text_length"] = text_length
        if error_type:
            record["error_type"] = error_type
        if error_message:
            record["error_message"] = error_message
        if details:
            record["details"] = details
        line = json.dumps(record, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
        try:
            if self._trace_file is not None:
                self._trace_file.write(f"{line}\n")
            if self._stderr_enabled:
                print(line, file=sys.stderr, flush=True)
        except OSError as exc:
            raise WorkerError("failed to write nemo_rnnt_streaming_worker trace") from exc


@dataclass(frozen=True)
class WorkerConfig:
    model_path: Path
    language: str
    sample_rate_hz: int
    channels: int
    audio_encoding: str
    emit_partial: bool
    chunk_size_samples: int
    max_partial_interval_ms: int


@dataclass(frozen=True)
class ModelCapability:
    model_class: str
    sample_rate_hz: int
    languages: tuple[str, ...]
    rnnt: bool
    cache_aware_streaming: bool
    chunk_size_samples: int
    max_partial_interval_ms: int
    supports_partials: bool


@dataclass(frozen=True)
class AudioChunk:
    session_id: str
    sample_count: int
    payload: bytes


class StreamingRuntime:
    def __init__(
        self,
        config: WorkerConfig,
        runner: "NemoStreamingModelRunner",
        trace: WorkerTrace | None = None,
    ) -> None:
        self._config = config
        self._runner = runner
        self._trace = trace if trace is not None else WorkerTrace.disabled()
        self._active_session_id = ""
        self._accepted_sample_count = 0

    def start(self, message: JsonMapping) -> tuple[JsonMapping, ...]:
        if self._active_session_id:
            raise WorkerError("start requires an idle worker session")
        _validate_stream_contract(message, self._config)
        session_id = _required_string(message, "session_id")
        self._runner.start_stream(session_id=session_id)
        self._active_session_id = session_id
        self._accepted_sample_count = 0
        self._trace.emit("stream_started", command="start", session_id=session_id)
        return ({"type": "stream_started", "session_id": session_id},)

    def accept_audio(self, message: JsonMapping) -> tuple[JsonMapping, ...]:
        self._ensure_streaming()
        chunk = _parse_audio_chunk(message)
        self._require_active_session(chunk.session_id, "audio")
        samples = _decode_float32le_samples(chunk.payload, sample_count=chunk.sample_count)
        self._accepted_sample_count += chunk.sample_count
        self._trace.emit(
            "audio_chunk_accepted",
            command="audio",
            session_id=chunk.session_id,
            sample_count=chunk.sample_count,
            accepted_sample_count=self._accepted_sample_count,
        )
        responses: list[JsonMapping] = []
        partial_text = self._runner.accept_audio(samples=samples)
        if self._config.emit_partial and partial_text:
            self._trace.emit(
                "partial_generated",
                command="audio",
                session_id=chunk.session_id,
                accepted_sample_count=self._accepted_sample_count,
                text_length=len(partial_text),
            )
            responses.append(
                {
                    "type": "partial",
                    "session_id": chunk.session_id,
                    "text": partial_text,
                    "sample_count": self._accepted_sample_count,
                }
            )
        self._trace.emit(
            "audio_accepted_response",
            command="audio",
            session_id=chunk.session_id,
            sample_count=chunk.sample_count,
            accepted_sample_count=self._accepted_sample_count,
        )
        responses.append(
            {
                "type": "audio_accepted",
                "session_id": chunk.session_id,
                "sample_count": chunk.sample_count,
            }
        )
        return tuple(responses)

    def drain(self, message: JsonMapping) -> tuple[JsonMapping, ...]:
        self._ensure_streaming()
        session_id = _required_string(message, "session_id")
        self._require_active_session(session_id, "drain")
        responses: list[JsonMapping] = []
        partial_text = self._runner.poll_partial()
        if self._config.emit_partial and partial_text:
            self._trace.emit(
                "partial_generated",
                command="drain",
                session_id=session_id,
                accepted_sample_count=self._accepted_sample_count,
                text_length=len(partial_text),
            )
            responses.append(
                {
                    "type": "partial",
                    "session_id": session_id,
                    "text": partial_text,
                    "sample_count": self._accepted_sample_count,
                }
            )
        responses.append({"type": "drained", "session_id": session_id})
        return tuple(responses)

    def finish(self, message: JsonMapping) -> tuple[JsonMapping, ...]:
        self._ensure_streaming()
        session_id = _required_string(message, "session_id")
        self._require_active_session(session_id, "finish")
        if self._accepted_sample_count <= 0:
            raise WorkerError("finish requires at least one accepted audio message")
        final_text = self._runner.finish_stream()
        self._trace.emit(
            "final_generated",
            command="finish",
            session_id=session_id,
            accepted_sample_count=self._accepted_sample_count,
            text_length=len(final_text),
        )
        self._active_session_id = ""
        return (
            {
                "type": "final",
                "session_id": session_id,
                "text": final_text,
                "sample_count": self._accepted_sample_count,
            },
            {"type": "finished", "session_id": session_id},
        )

    def cancel(self, message: JsonMapping) -> tuple[JsonMapping, ...]:
        self._ensure_streaming()
        session_id = _required_string(message, "session_id")
        self._require_active_session(session_id, "cancel")
        self._runner.reset_stream(reason="cancel")
        self._active_session_id = ""
        self._accepted_sample_count = 0
        self._trace.emit("stream_cancelled", command="cancel", session_id=session_id)
        return ({"type": "cancelled", "session_id": session_id},)

    def _ensure_streaming(self) -> None:
        if not self._active_session_id:
            raise WorkerError("stream command requires an active worker session")

    def _require_active_session(self, session_id: str, command_name: str) -> None:
        if session_id != self._active_session_id:
            raise WorkerError(f"{command_name} session_id does not match active stream")


class NemoStreamingModelRunner:
    def __init__(
        self,
        model,
        config: WorkerConfig,
        trace: WorkerTrace | None = None,
    ) -> None:
        self._model = model
        self._trace = trace if trace is not None else WorkerTrace.disabled()
        self._cache_aware_runner = _build_cache_aware_runner(model, config, self._trace)

    def start_stream(self, *, session_id: str) -> None:
        with redirect_stdout(sys.stderr):
            if self._cache_aware_runner is not None:
                self._cache_aware_runner.start_stream()
                return
            if hasattr(self._model, "start_stream"):
                self._model.start_stream(session_id)

    def accept_audio(self, *, samples: tuple[float, ...]) -> str:
        with redirect_stdout(sys.stderr):
            if self._cache_aware_runner is not None:
                return self._cache_aware_runner.accept_audio(samples=samples)
            if hasattr(self._model, "accept_audio"):
                start_ns = time.perf_counter_ns()
                self._trace.emit(
                    "model_accept_audio_start",
                    command="audio",
                    sample_count=len(samples),
                )
                text = _require_text_result(self._model.accept_audio(samples))
                self._trace.emit(
                    "model_accept_audio_finish",
                    command="audio",
                    sample_count=len(samples),
                    duration_ms=_duration_ms_since(start_ns),
                    text_length=len(text),
                )
                return text
            if hasattr(self._model, "transcribe_streaming_chunk"):
                start_ns = time.perf_counter_ns()
                self._trace.emit(
                    "model_transcribe_streaming_chunk_start",
                    command="audio",
                    sample_count=len(samples),
                )
                text = _require_text_result(self._model.transcribe_streaming_chunk(samples))
                self._trace.emit(
                    "model_transcribe_streaming_chunk_finish",
                    command="audio",
                    sample_count=len(samples),
                    duration_ms=_duration_ms_since(start_ns),
                    text_length=len(text),
                )
                return text
        raise WorkerError("model does not expose accept_audio/transcribe_streaming_chunk")

    def poll_partial(self) -> str:
        with redirect_stdout(sys.stderr):
            if self._cache_aware_runner is not None:
                return self._cache_aware_runner.poll_partial()
            if hasattr(self._model, "poll_partial"):
                return _optional_text_result(self._model.poll_partial())
        return ""

    def finish_stream(self) -> str:
        with redirect_stdout(sys.stderr):
            if self._cache_aware_runner is not None:
                return self._cache_aware_runner.finish_stream()
            if hasattr(self._model, "finish_stream"):
                return _require_text_result(self._model.finish_stream())
            if hasattr(self._model, "finalize_stream"):
                return _require_text_result(self._model.finalize_stream())
        raise WorkerError("model does not expose finish_stream/finalize_stream")

    def reset_stream(self, *, reason: str) -> None:
        with redirect_stdout(sys.stderr):
            if self._cache_aware_runner is not None:
                self._cache_aware_runner.reset_stream(reason=reason)
                return
            if hasattr(self._model, "reset_stream"):
                self._model.reset_stream(reason)
                return
            if hasattr(self._model, "reset"):
                self._model.reset()
                return
        raise WorkerError("model does not expose reset_stream/reset")


class CacheAwareConformerStreamingRunner:
    def __init__(
        self,
        model,
        config: WorkerConfig,
        trace: WorkerTrace | None = None,
    ) -> None:
        _require_module("numpy")
        _require_module("torch")
        _require_module("nemo.collections.asr.parts.utils.streaming_utils")
        self._np = importlib.import_module("numpy")
        self._torch = importlib.import_module("torch")
        streaming_utils = importlib.import_module(
            "nemo.collections.asr.parts.utils.streaming_utils"
        )
        if not hasattr(streaming_utils, "CacheAwareStreamingAudioBuffer"):
            raise WorkerError("NeMo CacheAwareStreamingAudioBuffer is unavailable")
        self._model = model
        self._config = config
        self._trace = trace if trace is not None else WorkerTrace.disabled()
        self._buffer_class = streaming_utils.CacheAwareStreamingAudioBuffer
        self._buffer = None
        self._stream_id = -1
        self._cache_last_channel = None
        self._cache_last_time = None
        self._cache_last_channel_len = None
        self._previous_hypotheses = None
        self._previous_pred_out = None
        self._step_num = 0
        self._last_text = ""
        self._configure_cache_aware_streaming()

    def start_stream(self) -> None:
        encoder = _required_attr(self._model, "encoder")
        if not hasattr(encoder, "get_initial_cache_state"):
            raise WorkerError("model encoder does not expose get_initial_cache_state")
        self._buffer = self._buffer_class(model=self._model, online_normalization=False)
        caches = encoder.get_initial_cache_state(batch_size=1)
        if type(caches) is not tuple or len(caches) != 3:
            raise WorkerError("encoder initial cache state must contain three tensors")
        self._cache_last_channel = caches[0]
        self._cache_last_time = caches[1]
        self._cache_last_channel_len = caches[2]
        self._previous_hypotheses = None
        self._previous_pred_out = None
        self._stream_id = -1
        self._step_num = 0
        self._last_text = ""
        self._trace.emit(
            "cache_aware_stream_started",
            details=_streaming_cfg_trace_details(encoder.streaming_cfg),
        )

    def accept_audio(self, *, samples: tuple[float, ...]) -> str:
        buffer = self._require_buffer()
        audio = self._np.asarray(samples, dtype=self._np.float32)
        append_start_ns = time.perf_counter_ns()
        self._trace.emit(
            "cache_aware_buffer_append_start",
            command="audio",
            sample_count=len(samples),
            details={"stream_id": self._stream_id},
        )
        if self._stream_id < 0:
            _, _, returned_stream_id = buffer.append_audio(audio, stream_id=-1)
            self._stream_id = self._resolve_initial_stream_id(
                buffer,
                returned_stream_id=returned_stream_id,
            )
        else:
            _, _, returned_stream_id = buffer.append_audio(
                audio,
                stream_id=self._stream_id,
            )
            if returned_stream_id != self._stream_id:
                raise WorkerError(
                    "cache-aware buffer changed stream_id during single-stream append"
                )
        self._trace.emit(
            "cache_aware_buffer_append_finish",
            command="audio",
            sample_count=len(samples),
            duration_ms=_duration_ms_since(append_start_ns),
            details={"stream_id": self._stream_id},
        )
        return self._drain_available(final=False)

    def poll_partial(self) -> str:
        return self._last_text

    def finish_stream(self) -> str:
        final_text = self._drain_available(final=True)
        if final_text:
            self._last_text = final_text
        self._trace.emit(
            "cache_aware_finish_stream",
            command="finish",
            text_length=len(self._last_text),
        )
        return self._last_text

    def reset_stream(self, *, reason: str) -> None:
        if self._buffer is not None:
            self._buffer.reset_buffer()
        self._buffer = None
        self._stream_id = -1
        self._last_text = ""
        self._trace.emit(
            "cache_aware_stream_reset",
            command="cancel",
            details={"reason": reason},
        )

    def _require_buffer(self):
        if self._buffer is None:
            raise WorkerError("cache-aware runner requires start_stream before audio")
        return self._buffer

    @staticmethod
    def _resolve_initial_stream_id(buffer, *, returned_stream_id: int) -> int:
        if returned_stream_id >= 0:
            return returned_stream_id
        try:
            streams_length = buffer.streams_length
        except AttributeError as exc:
            raise WorkerError(
                "cache-aware buffer did not expose streams_length after first append"
            ) from exc
        if streams_length is None:
            raise WorkerError("cache-aware buffer has no stream length after first append")
        try:
            stream_count = len(streams_length)
        except TypeError as exc:
            raise WorkerError("cache-aware buffer stream length is not countable") from exc
        if stream_count != 1:
            raise WorkerError(
                "cache-aware buffer first append must create exactly one stream"
            )
        return 0

    def _drain_available(self, *, final: bool) -> str:
        buffer = self._require_buffer()
        latest_text = ""
        chunk_count = 0
        drain_start_ns = time.perf_counter_ns()
        self._trace.emit(
            "cache_aware_buffer_drain_start",
            command="finish" if final else "audio",
            details={"final": final},
        )
        buffer_iterator = None
        while final or self._has_complete_non_final_chunk(buffer):
            if buffer_iterator is None:
                buffer_iterator = iter(buffer)
            try:
                chunk_audio, chunk_lengths = next(buffer_iterator)
            except StopIteration as exc:
                if final:
                    break
                raise WorkerError(
                    "cache-aware buffer reported a complete chunk but iterator ended"
                ) from exc
            chunk_count += 1
            chunk_time_length = _chunk_time_length(chunk_audio)
            self._trace.emit(
                "cache_aware_buffer_chunk",
                command="finish" if final else "audio",
                chunk_count=chunk_count,
                details={
                    "chunk_time_length": chunk_time_length,
                    "chunk_lengths": _trace_json_value(chunk_lengths),
                    "final": final,
                },
            )
            latest_text = self._conformer_stream_step(
                chunk_audio=chunk_audio,
                chunk_lengths=chunk_lengths,
                # In live append mode, an empty buffer only means all currently
                # appended audio was consumed. Only finish may mark a final chunk.
                keep_all_outputs=final,
            )
        if latest_text:
            self._last_text = latest_text
        self._trace.emit(
            "cache_aware_buffer_drain_finish",
            command="finish" if final else "audio",
            chunk_count=chunk_count,
            duration_ms=_duration_ms_since(drain_start_ns),
            text_length=len(latest_text),
            details={"final": final},
        )
        return latest_text

    def _has_complete_non_final_chunk(self, buffer) -> bool:
        buffer_idx, available_length = self._buffer_position(buffer)
        return available_length >= self._current_non_final_chunk_size(
            buffer_idx=buffer_idx,
        )

    def _buffer_position(self, buffer) -> tuple[int, int]:
        audio_buffer = _required_cache_buffer_attr(buffer, "buffer")
        buffer_idx = _required_cache_buffer_attr(buffer, "buffer_idx")
        if type(buffer_idx) is not int or buffer_idx < 0:
            raise WorkerError("cache-aware buffer buffer_idx must be a non-negative integer")
        if not hasattr(audio_buffer, "size"):
            raise WorkerError("cache-aware buffer audio does not expose size")
        buffer_length = audio_buffer.size(-1)
        if type(buffer_length) is not int or buffer_length < 0:
            raise WorkerError("cache-aware buffer length must be a non-negative integer")
        if buffer_idx > buffer_length:
            raise WorkerError("cache-aware buffer_idx exceeds buffer length")
        return buffer_idx, buffer_length - buffer_idx

    def _current_non_final_chunk_size(self, *, buffer_idx: int) -> int:
        encoder = _required_attr(self._model, "encoder")
        streaming_cfg = _required_attr(encoder, "streaming_cfg")
        chunk_size = _required_attr(streaming_cfg, "chunk_size")
        if type(chunk_size) is int:
            return _require_positive_chunk_size(chunk_size)
        if type(chunk_size) is list or type(chunk_size) is tuple:
            chunk_index = 0 if buffer_idx == 0 else 1
            if len(chunk_size) <= chunk_index:
                raise WorkerError(
                    "streaming_cfg.chunk_size must contain first and later chunk sizes"
                )
            return _require_positive_chunk_size(chunk_size[chunk_index])
        raise WorkerError("streaming_cfg.chunk_size must be an integer or pair")

    def _conformer_stream_step(
        self,
        *,
        chunk_audio,
        chunk_lengths,
        keep_all_outputs: bool,
    ) -> str:
        if not hasattr(self._model, "conformer_stream_step"):
            raise WorkerError("model does not expose conformer_stream_step")
        chunk_time_length, required_max_audio_length = (
            self._ensure_encoder_max_audio_length(chunk_audio=chunk_audio)
        )
        step_start_ns = time.perf_counter_ns()
        self._trace.emit(
            "conformer_stream_step_start",
            step_num=self._step_num + 1,
            details={
                "chunk_time_length": chunk_time_length,
                "keep_all_outputs": keep_all_outputs,
                "required_max_audio_length": required_max_audio_length,
            },
        )
        with self._torch.inference_mode():
            try:
                outputs = self._model.conformer_stream_step(
                    processed_signal=chunk_audio,
                    processed_signal_length=chunk_lengths,
                    cache_last_channel=self._cache_last_channel,
                    cache_last_time=self._cache_last_time,
                    cache_last_channel_len=self._cache_last_channel_len,
                    keep_all_outputs=keep_all_outputs,
                    previous_hypotheses=self._previous_hypotheses,
                    previous_pred_out=self._previous_pred_out,
                    drop_extra_pre_encoded=self._drop_extra_pre_encoded(),
                    return_transcription=True,
                )
            except Exception as exc:
                self._trace.emit(
                    "conformer_stream_step_exception",
                    step_num=self._step_num + 1,
                    duration_ms=_duration_ms_since(step_start_ns),
                    error_type=exc.__class__.__name__,
                    error_message=str(exc),
                    details={
                        "chunk_time_length": chunk_time_length,
                        "required_max_audio_length": required_max_audio_length,
                    },
                )
                raise
        if type(outputs) is not tuple or len(outputs) != 6:
            raise WorkerError("conformer_stream_step must return six values")
        (
            self._previous_pred_out,
            transcribed_texts,
            self._cache_last_channel,
            self._cache_last_time,
            self._cache_last_channel_len,
            self._previous_hypotheses,
        ) = outputs
        self._step_num += 1
        text = _first_transcription_text(transcribed_texts)
        self._trace.emit(
            "conformer_stream_step_finish",
            step_num=self._step_num,
            duration_ms=_duration_ms_since(step_start_ns),
            text_length=len(text),
            details={
                "chunk_time_length": chunk_time_length,
                "required_max_audio_length": required_max_audio_length,
            },
        )
        return text

    def _ensure_encoder_max_audio_length(self, *, chunk_audio) -> tuple[int, int]:
        encoder = _required_attr(self._model, "encoder")
        streaming_cfg = _required_attr(encoder, "streaming_cfg")
        last_channel_cache_size = _required_attr(
            streaming_cfg,
            "last_channel_cache_size",
        )
        if type(last_channel_cache_size) is not int or last_channel_cache_size <= 0:
            raise WorkerError(
                "streaming_cfg.last_channel_cache_size must be a positive integer"
            )
        if not hasattr(chunk_audio, "size"):
            raise WorkerError("cache-aware chunk_audio does not expose size")
        chunk_time_length = chunk_audio.size(-1)
        if type(chunk_time_length) is not int or chunk_time_length <= 0:
            raise WorkerError(
                "cache-aware chunk_audio time length must be a positive integer"
            )
        if not hasattr(encoder, "set_max_audio_length"):
            raise WorkerError("model encoder does not expose set_max_audio_length")
        required_max_audio_length = last_channel_cache_size + chunk_time_length
        try:
            encoder.set_max_audio_length(required_max_audio_length)
        except Exception as exc:
            raise WorkerError("model encoder failed to set max audio length") from exc
        return chunk_time_length, required_max_audio_length

    def _configure_cache_aware_streaming(self) -> None:
        cfg = _required_attr(self._model, "cfg")
        preprocessor_config = _required_config_section(cfg, "preprocessor")
        encoder_config = _required_config_section(cfg, "encoder")
        window_stride = _required_config_positive_number(
            preprocessor_config,
            "window_stride",
        )
        subsampling_factor = _required_config_positive_int(
            encoder_config,
            "subsampling_factor",
        )
        encoder_chunk_size = self._encoder_chunk_size(
            window_stride=window_stride,
            subsampling_factor=subsampling_factor,
        )
        shift_size = max(1, encoder_chunk_size // 2)
        encoder = _required_attr(self._model, "encoder")
        if _is_full_context_attention(encoder_config, encoder):
            if not hasattr(encoder, "set_default_att_context_size"):
                raise WorkerError(
                    "model encoder does not expose set_default_att_context_size"
                )
            attention_context = _select_default_finite_attention_context(
                encoder,
                encoder_config,
            )
            try:
                encoder.set_default_att_context_size(list(attention_context))
            except Exception as exc:
                raise WorkerError(
                    "model encoder failed to set default attention context"
                ) from exc
            self._trace.emit(
                "cache_aware_attention_context_configured",
                details={"att_context_size": list(attention_context)},
            )
        if not hasattr(encoder, "setup_streaming_params"):
            raise WorkerError("model encoder does not expose setup_streaming_params")
        try:
            encoder.setup_streaming_params(
                chunk_size=encoder_chunk_size,
                shift_size=shift_size,
                left_chunks=2,
            )
        except Exception as exc:
            raise WorkerError("model encoder failed to set streaming params") from exc
        streaming_cfg = _required_attr(encoder, "streaming_cfg")
        last_channel_cache_size = _required_attr(
            streaming_cfg,
            "last_channel_cache_size",
        )
        if type(last_channel_cache_size) is not int or last_channel_cache_size <= 0:
            raise WorkerError(
                "streaming_cfg.last_channel_cache_size must be a positive integer"
            )
        self._trace.emit(
            "cache_aware_streaming_configured",
            details={
                "encoder_chunk_size": encoder_chunk_size,
                "shift_size": shift_size,
                "left_chunks": 2,
                "streaming_cfg": _streaming_cfg_trace_details(streaming_cfg),
            },
        )

    def _encoder_chunk_size(
        self,
        *,
        window_stride: float,
        subsampling_factor: int,
    ) -> int:
        encoder_token_samples = (
            self._config.sample_rate_hz * window_stride * subsampling_factor
        )
        if not math.isfinite(encoder_token_samples) or encoder_token_samples <= 0:
            raise WorkerError("encoder token duration must be positive")
        requested = self._config.chunk_size_samples / encoder_token_samples
        if not math.isfinite(requested) or requested <= 0:
            raise WorkerError("derived encoder chunk size must be positive")
        return max(10, math.ceil(requested))

    def _drop_extra_pre_encoded(self) -> int:
        if self._step_num == 0:
            return 0
        encoder = _required_attr(self._model, "encoder")
        streaming_cfg = _required_attr(encoder, "streaming_cfg")
        value = _required_attr(streaming_cfg, "drop_extra_pre_encoded")
        if type(value) is int:
            return value
        if type(value) is list or type(value) is tuple:
            if len(value) == 0 or type(value[-1]) is not int:
                raise WorkerError("drop_extra_pre_encoded must contain integers")
            return value[-1]
        raise WorkerError("drop_extra_pre_encoded must be an integer")


def main() -> int:
    trace = WorkerTrace.disabled()
    runtime: StreamingRuntime | None = None
    try:
        trace = WorkerTrace.from_environment()
        for line in sys.stdin:
            message = _load_json_line(line)
            message_type = _required_string(message, "type")
            trace.emit(
                "command_received",
                command=message_type,
                session_id=_optional_message_string(message, "session_id"),
            )
            if message_type == "health":
                config = _config_from_message(message)
                trace.emit("health_start", command="health")
                capability, runner = _load_validated_model_runner(config, trace)
                runtime = StreamingRuntime(config, runner, trace)
                trace.emit(
                    "health_ok",
                    command="health",
                    details={
                        "cache_aware_streaming": capability.cache_aware_streaming,
                        "chunk_size_samples": config.chunk_size_samples,
                        "emit_partial": config.emit_partial,
                        "language": config.language,
                        "max_partial_interval_ms": config.max_partial_interval_ms,
                        "model_class": capability.model_class,
                        "sample_rate_hz": capability.sample_rate_hz,
                    },
                )
                _emit(
                    {
                        "type": "health_ok",
                        "model_class": capability.model_class,
                        "cache_aware_streaming": capability.cache_aware_streaming,
                        "sample_rate_hz": capability.sample_rate_hz,
                        "channels": config.channels,
                        "audio_encoding": config.audio_encoding,
                        "streaming": True,
                        "final_results_only": not config.emit_partial,
                        "supports_partials": capability.supports_partials,
                        "language": config.language,
                        "chunk_size_samples": config.chunk_size_samples,
                        "max_partial_interval_ms": config.max_partial_interval_ms,
                    }
                )
                continue
            if message_type == "start":
                if runtime is None:
                    config = _config_from_message(message)
                    _, runner = _load_validated_model_runner(config, trace)
                    runtime = StreamingRuntime(config, runner, trace)
                _emit_many(runtime.start(message))
                continue
            if runtime is None:
                raise WorkerError(f"{message_type} requires a prior health or start message")
            if message_type == "audio":
                _emit_many(runtime.accept_audio(message))
                continue
            if message_type == "drain":
                _emit_many(runtime.drain(message))
                continue
            if message_type == "finish":
                _emit_many(runtime.finish(message))
                continue
            if message_type == "cancel":
                _emit_many(runtime.cancel(message))
                continue
            raise WorkerError(f"unknown message type: {message_type}")
        return 0
    except WorkerError as exc:
        trace.emit(
            "worker_error",
            error_type=exc.__class__.__name__,
            error_message=str(exc),
        )
        print(str(exc), file=sys.stderr)
        return 1
    except Exception as exc:
        trace.emit(
            "worker_exception",
            error_type=exc.__class__.__name__,
            error_message=str(exc),
        )
        raise
    finally:
        trace.close()


def _load_validated_model_runner(
    config: WorkerConfig,
    trace: WorkerTrace,
) -> tuple[ModelCapability, NemoStreamingModelRunner]:
    with redirect_stdout(sys.stderr):
        model = load_nemo_model(config.model_path)
        capability = inspect_model_capability(model)
        validate_model_capability(capability, config)
        runner = NemoStreamingModelRunner(model, config, trace)
    return capability, runner


def load_nemo_model(model_path: Path):
    for module_name in (
        "nemo",
        "nemo.collections",
        "nemo.collections.asr",
        "nemo.collections.asr.models",
    ):
        if importlib.util.find_spec(module_name) is None:
            raise WorkerError("NeMo ASR module is unavailable in this worker environment")
    models_module = importlib.import_module("nemo.collections.asr.models")
    if not hasattr(models_module, "ASRModel"):
        raise WorkerError("NeMo ASRModel is unavailable")
    asr_model_class = models_module.ASRModel
    if not hasattr(asr_model_class, "restore_from"):
        raise WorkerError("NeMo ASRModel.restore_from is unavailable")
    model = asr_model_class.restore_from(str(model_path))
    if not hasattr(model, "eval"):
        raise WorkerError("NeMo model does not expose eval")
    try:
        model.eval()
    except Exception as exc:
        raise WorkerError("NeMo model failed to enter eval mode") from exc
    return model


def inspect_model_capability(model) -> ModelCapability:
    cfg = _required_attr(model, "cfg")
    model_class = _extract_model_class(model, cfg)
    preprocessor = _required_config_section(cfg, "preprocessor")
    decoder = _required_config_section(cfg, "decoder")
    joint = _required_config_section(cfg, "joint")
    encoder_config = _required_config_section(cfg, "encoder")
    runtime_encoder = _required_attr(model, "encoder")
    sample_rate_hz = _required_config_int(preprocessor, "sample_rate")
    languages = _extract_languages(cfg)
    rnnt = _is_rnnt_model_class(model_class) or _config_section_mentions(decoder, "rnnt")
    cache_aware_streaming = _encoder_supports_cache_aware_streaming(runtime_encoder)
    chunk_size_samples = _optional_config_int(encoder_config, "chunk_size_samples", default_value=0)
    max_partial_interval_ms = _optional_config_int(
        encoder_config, "max_partial_interval_ms", default_value=0
    )
    _required_config_section(joint, "jointnet")
    return ModelCapability(
        model_class=model_class,
        sample_rate_hz=sample_rate_hz,
        languages=languages,
        rnnt=rnnt,
        cache_aware_streaming=cache_aware_streaming,
        chunk_size_samples=chunk_size_samples,
        max_partial_interval_ms=max_partial_interval_ms,
        supports_partials=_model_supports_partials(model),
    )


def validate_model_capability(capability: ModelCapability, config: WorkerConfig) -> None:
    if not capability.rnnt:
        raise WorkerError(f"model must be RNNT/Transducer; got {capability.model_class}")
    if not capability.cache_aware_streaming:
        raise WorkerError("model must expose cache-aware streaming support")
    if capability.sample_rate_hz != config.sample_rate_hz:
        raise WorkerError(
            f"model sample_rate {capability.sample_rate_hz} "
            f"does not match configured {config.sample_rate_hz}"
        )
    if capability.languages and config.language not in capability.languages:
        raise WorkerError(f"language {config.language} is not supported by model")
    if config.emit_partial and not capability.supports_partials:
        raise WorkerError("model does not expose partial result support")


def _config_from_message(message: JsonMapping) -> WorkerConfig:
    model_path = _require_readable_file(_required_string(message, "model_path"), "model_path")
    language = _required_string(message, "language")
    sample_rate_hz = _required_positive_int(message, "sample_rate_hz")
    channels = _required_positive_int(message, "channels")
    audio_encoding = _required_string(message, "audio_encoding")
    emit_partial = _required_bool(message, "emit_partial")
    chunk_size_samples = _required_positive_int(message, "chunk_size_samples")
    max_partial_interval_ms = _required_positive_int(message, "max_partial_interval_ms")
    if channels != SUPPORTED_CHANNELS:
        raise WorkerError("channels must be 1; upstream must provide mono audio")
    if audio_encoding != SUPPORTED_AUDIO_ENCODING:
        raise WorkerError(
            f"audio_encoding must be {SUPPORTED_AUDIO_ENCODING}; transcoding is not performed"
        )
    return WorkerConfig(
        model_path=model_path,
        language=language,
        sample_rate_hz=sample_rate_hz,
        channels=channels,
        audio_encoding=audio_encoding,
        emit_partial=emit_partial,
        chunk_size_samples=chunk_size_samples,
        max_partial_interval_ms=max_partial_interval_ms,
    )


def _validate_stream_contract(message: JsonMapping, config: WorkerConfig) -> None:
    candidate = _config_from_message(message)
    if candidate != config:
        raise WorkerError("start stream contract does not match worker health contract")


def _parse_audio_chunk(message: JsonMapping) -> AudioChunk:
    session_id = _required_string(message, "session_id")
    encoding = _required_string(message, "encoding")
    sample_count = _required_positive_int(message, "sample_count")
    data = _required_string(message, "data")
    if encoding != WIRE_AUDIO_ENCODING:
        raise WorkerError(f"audio encoding must be {WIRE_AUDIO_ENCODING}")
    try:
        payload = base64.b64decode(data, validate=True)
    except binascii.Error as exc:
        raise WorkerError("audio data is not valid base64") from exc
    expected_bytes = sample_count * SUPPORTED_CHANNELS * 4
    if len(payload) != expected_bytes:
        raise WorkerError(f"sample_count mismatch: expected {expected_bytes} bytes, got {len(payload)}")
    return AudioChunk(session_id=session_id, sample_count=sample_count, payload=payload)


def _decode_float32le_samples(payload: bytes, *, sample_count: int) -> tuple[float, ...]:
    samples: list[float] = []
    for index, (sample,) in enumerate(struct.iter_unpack("<f", payload)):
        if not math.isfinite(sample):
            raise WorkerError(f"audio sample {index} is not finite")
        if sample < -1.0 or sample > 1.0:
            raise WorkerError(f"audio sample {index} is outside normalized float32 range")
        samples.append(sample)
    if len(samples) != sample_count:
        raise WorkerError("decoded sample_count mismatch")
    return tuple(samples)


def _environment_bool(name: str) -> bool:
    value = os.environ.get(name, "").strip().lower()
    if not value:
        return False
    if value in ("0", "false", "no", "off"):
        return False
    if value in ("1", "true", "yes", "on"):
        return True
    raise WorkerError(f"{name} must be one of 0/1/false/true/no/yes/off/on")


def _duration_ms_since(start_ns: int) -> float:
    return (time.perf_counter_ns() - start_ns) / 1_000_000.0


def _optional_message_string(message: JsonMapping, key: str) -> str:
    value = message.get(key)
    if type(value) is str:
        return value
    return ""


def _chunk_time_length(chunk_audio) -> int:
    if not hasattr(chunk_audio, "size"):
        raise WorkerError("cache-aware chunk_audio does not expose size")
    chunk_time_length = chunk_audio.size(-1)
    if type(chunk_time_length) is not int or chunk_time_length <= 0:
        raise WorkerError("cache-aware chunk_audio time length must be a positive integer")
    return chunk_time_length


def _streaming_cfg_trace_details(streaming_cfg) -> JsonMapping:
    details: JsonMapping = {}
    for name in (
        "chunk_size",
        "shift_size",
        "cache_drop_size",
        "last_channel_cache_size",
        "valid_out_len",
        "pre_encode_cache_size",
        "drop_extra_pre_encoded",
    ):
        value = _optional_attr(streaming_cfg, name)
        if value is not None:
            details[name] = _trace_json_value(value)
    return details


def _trace_json_value(value) -> JsonValue:
    if value is None:
        return None
    if type(value) is str or type(value) is int or type(value) is float or type(value) is bool:
        return value
    if type(value) is list or type(value) is tuple:
        return [_trace_json_value(item) for item in value]
    return value.__class__.__name__


def _load_json_line(line: str) -> JsonMapping:
    try:
        decoded = json.loads(line)
    except json.JSONDecodeError as exc:
        raise WorkerError(f"malformed JSON line: {exc.msg}") from exc
    value = _validate_json_value(decoded)
    if type(value) is not dict:
        raise WorkerError("JSON line must be a mapping")
    return value


def _validate_json_value(value) -> JsonValue:
    if value is None:
        return None
    if type(value) is str or type(value) is int or type(value) is float or type(value) is bool:
        return value
    if type(value) is list:
        return [_validate_json_value(item) for item in value]
    if type(value) is dict:
        validated: JsonMapping = {}
        for key, item in value.items():
            if type(key) is not str:
                raise WorkerError("JSON object keys must be strings")
            validated[key] = _validate_json_value(item)
        return validated
    raise WorkerError("unsupported JSON value")


def _emit(message: JsonMapping) -> None:
    print(json.dumps(message, ensure_ascii=False, separators=(",", ":")), flush=True)


def _emit_many(messages: tuple[JsonMapping, ...]) -> None:
    for message in messages:
        _emit(message)


def _require_readable_file(value: str, label: str) -> Path:
    path = Path(value).expanduser()
    try:
        resolved = path.resolve(strict=True)
    except FileNotFoundError as exc:
        raise WorkerError(f"{label} file does not exist: {path}") from exc
    if not resolved.is_file():
        raise WorkerError(f"{label} path is not a file: {resolved}")
    if not os.access(resolved, os.R_OK):
        raise WorkerError(f"{label} file is not readable: {resolved}")
    return resolved


def _required_string(document: JsonMapping, key: str) -> str:
    if key not in document:
        raise WorkerError(f"missing required field: {key}")
    value = document[key]
    if type(value) is not str or not value.strip():
        raise WorkerError(f"{key} must be a non-empty string")
    return value


def _required_bool(document: JsonMapping, key: str) -> bool:
    if key not in document:
        raise WorkerError(f"missing required field: {key}")
    value = document[key]
    if type(value) is not bool:
        raise WorkerError(f"{key} must be a bool")
    return value


def _required_int(document: JsonMapping, key: str) -> int:
    if key not in document:
        raise WorkerError(f"missing required field: {key}")
    value = document[key]
    if type(value) is not int:
        raise WorkerError(f"{key} must be an integer")
    return value


def _required_positive_int(document: JsonMapping, key: str) -> int:
    value = _required_int(document, key)
    if value <= 0:
        raise WorkerError(f"{key} must be positive")
    return value


def _required_attr(value, name: str):
    if not hasattr(value, name):
        raise WorkerError(f"model is missing required attribute: {name}")
    return getattr(value, name)


def _required_cache_buffer_attr(buffer, name: str):
    if not hasattr(buffer, name):
        raise WorkerError(f"cache-aware buffer is missing required attribute: {name}")
    return getattr(buffer, name)


def _require_positive_chunk_size(value) -> int:
    if type(value) is not int or value <= 0:
        raise WorkerError("streaming_cfg.chunk_size values must be positive integers")
    return value


def _required_config_section(config, name: str):
    if isinstance(config, dict):
        if name not in config:
            raise WorkerError(f"model config is missing section: {name}")
        return config[name]
    if not hasattr(config, name):
        raise WorkerError(f"model config is missing section: {name}")
    return getattr(config, name)


def _required_config_int(config, name: str) -> int:
    value = _required_config_section(config, name)
    if type(value) is not int:
        raise WorkerError(f"model config {name} must be an integer")
    return value


def _required_config_positive_int(config, name: str) -> int:
    value = _required_config_int(config, name)
    if value <= 0:
        raise WorkerError(f"model config {name} must be positive")
    return value


def _required_config_positive_number(config, name: str) -> float:
    value = _required_config_section(config, name)
    if type(value) is not int and type(value) is not float:
        raise WorkerError(f"model config {name} must be numeric")
    number = float(value)
    if not math.isfinite(number) or number <= 0.0:
        raise WorkerError(f"model config {name} must be positive")
    return number


def _optional_config_int(config, name: str, *, default_value: int) -> int:
    if isinstance(config, dict):
        if name not in config:
            return default_value
        value = config[name]
    elif hasattr(config, name):
        value = getattr(config, name)
    else:
        return default_value
    if type(value) is not int:
        raise WorkerError(f"model config {name} must be an integer")
    return value


def _extract_model_class(model, cfg) -> str:
    class_name = model.__class__.__name__
    if class_name:
        return class_name
    if isinstance(cfg, dict) and "target" in cfg and type(cfg["target"]) is str:
        return cfg["target"]
    if hasattr(cfg, "target"):
        target = getattr(cfg, "target")
        if type(target) is str:
            return target
    raise WorkerError("model class cannot be determined")


def _extract_languages(cfg) -> tuple[str, ...]:
    if isinstance(cfg, dict) and "languages" in cfg:
        return _string_tuple(cfg["languages"], "languages")
    if hasattr(cfg, "languages"):
        return _string_tuple(getattr(cfg, "languages"), "languages")
    if isinstance(cfg, dict) and "language" in cfg:
        return (_required_config_string(cfg, "language"),)
    if hasattr(cfg, "language"):
        value = getattr(cfg, "language")
        if type(value) is str and value:
            return (value,)
    return ()


def _required_config_string(config, name: str) -> str:
    value = _required_config_section(config, name)
    if type(value) is not str or not value.strip():
        raise WorkerError(f"model config {name} must be a non-empty string")
    return value


def _string_tuple(value, label: str) -> tuple[str, ...]:
    if type(value) is not list and type(value) is not tuple:
        raise WorkerError(f"model config {label} must be a string list")
    strings: list[str] = []
    for item in value:
        if type(item) is not str or not item.strip():
            raise WorkerError(f"model config {label} must contain only non-empty strings")
        strings.append(item)
    return tuple(strings)


def _is_rnnt_model_class(model_class: str) -> bool:
    lowered = model_class.lower()
    return "rnnt" in lowered or "transducer" in lowered


def _config_section_mentions(config, needle: str) -> bool:
    if isinstance(config, dict):
        values = tuple(config.values())
    elif hasattr(config, "__dict__"):
        values = tuple(vars(config).values())
    else:
        values = ()
    for value in values:
        if type(value) is str and needle in value.lower():
            return True
    return False


def _encoder_supports_cache_aware_streaming(encoder) -> bool:
    if isinstance(encoder, dict):
        if encoder.get("cache_aware_streaming") is True:
            return True
        if encoder.get("streaming") == "cache_aware":
            return True
        return "streaming_cfg" in encoder
    if getattr(encoder, "cache_aware_streaming", False) is True:
        return True
    if getattr(encoder, "streaming", "") == "cache_aware":
        return True
    if hasattr(encoder, "setup_streaming_params") and hasattr(
        encoder, "get_initial_cache_state"
    ):
        return True
    return hasattr(encoder, "streaming_cfg")


def _is_full_context_attention(encoder_config, encoder) -> bool:
    configured_context = _optional_config_section(encoder_config, "att_context_size")
    if _is_full_context_value(configured_context):
        return True
    return _is_full_context_value(_optional_attr(encoder, "att_context_size"))


def _is_full_context_value(value) -> bool:
    if type(value) is not list and type(value) is not tuple:
        return False
    if len(value) != 2:
        return False
    return value[0] == -1 and value[1] == -1


def _select_default_finite_attention_context(
    encoder,
    encoder_config,
) -> tuple[int, int]:
    supported_contexts = _supported_attention_contexts(encoder, encoder_config)
    if not supported_contexts:
        raise WorkerError(
            "model encoder does not expose supported attention contexts; "
            "refusing implicit finite context setup"
        )
    requested_context = DEFAULT_FINITE_ATTENTION_CONTEXT
    if requested_context in supported_contexts:
        return requested_context
    if all(_is_full_context_pair(context) for context in supported_contexts):
        raise WorkerError(
            "model encoder does not support a finite attention context; "
            f"supported_contexts={_attention_contexts_text(supported_contexts)}"
        )
    raise WorkerError(
        "model encoder does not support requested finite attention context "
        f"{_attention_context_text(requested_context)}; "
        f"supported_contexts={_attention_contexts_text(supported_contexts)}"
    )


def _supported_attention_contexts(encoder, encoder_config) -> tuple[tuple[int, int], ...]:
    for name in (
        "att_context_size_all",
        "supported_att_context_size",
        "supported_att_context_sizes",
    ):
        value = _optional_attr(encoder, name)
        if value is not None:
            return _attention_contexts_from_value(value, f"encoder.{name}")
    config_value = _optional_config_section(encoder_config, "att_context_size_all")
    if config_value is not None:
        return _attention_contexts_from_value(
            config_value,
            "model config encoder.att_context_size_all",
        )
    return ()


def _attention_contexts_from_value(value, label: str) -> tuple[tuple[int, int], ...]:
    if _is_attention_context_pair(value):
        return (_attention_context_pair(value, label),)
    if type(value) is not list and type(value) is not tuple:
        raise WorkerError(f"{label} must be an attention context pair list")
    contexts: list[tuple[int, int]] = []
    for item in value:
        contexts.append(_attention_context_pair(item, label))
    return tuple(contexts)


def _attention_context_pair(value, label: str) -> tuple[int, int]:
    if not _is_attention_context_pair(value):
        raise WorkerError(f"{label} must contain integer attention context pairs")
    return (value[0], value[1])


def _is_attention_context_pair(value) -> bool:
    if type(value) is not list and type(value) is not tuple:
        return False
    if len(value) != 2:
        return False
    return type(value[0]) is int and type(value[1]) is int


def _is_full_context_pair(value: tuple[int, int]) -> bool:
    return value == (-1, -1)


def _attention_context_text(value: tuple[int, int]) -> str:
    return f"[{value[0]}, {value[1]}]"


def _attention_contexts_text(values: tuple[tuple[int, int], ...]) -> str:
    return "[" + ", ".join(_attention_context_text(value) for value in values) + "]"


def _optional_config_section(config, name: str):
    if isinstance(config, dict):
        if name in config:
            return config[name]
        return None
    if hasattr(config, name):
        return getattr(config, name)
    return None


def _optional_attr(value, name: str):
    if hasattr(value, name):
        return getattr(value, name)
    return None


def _model_supports_partials(model) -> bool:
    return (
        hasattr(model, "accept_audio")
        or hasattr(model, "transcribe_streaming_chunk")
        or hasattr(model, "conformer_stream_step")
    )


def _build_cache_aware_runner(
    model,
    config: WorkerConfig,
    trace: WorkerTrace,
) -> CacheAwareConformerStreamingRunner | None:
    if not hasattr(model, "conformer_stream_step"):
        return None
    if not hasattr(model, "encoder"):
        return None
    return CacheAwareConformerStreamingRunner(model, config, trace)


def _require_module(module_name: str) -> None:
    parts = module_name.split(".")
    for index in range(1, len(parts) + 1):
        candidate = ".".join(parts[:index])
        if importlib.util.find_spec(candidate) is None:
            raise WorkerError(f"required module is unavailable: {module_name}")


def _require_text_result(value) -> str:
    text = _optional_text_result(value)
    if not text:
        raise WorkerError("model streaming API must return non-empty text")
    return text


def _optional_text_result(value) -> str:
    if value is None:
        return ""
    if type(value) is str:
        return value
    if isinstance(value, dict) and "text" in value and type(value["text"]) is str:
        return value["text"]
    if hasattr(value, "text"):
        text = getattr(value, "text")
        if type(text) is str:
            return text
    raise WorkerError("model streaming API must return text")


def _first_transcription_text(value) -> str:
    if type(value) is list or type(value) is tuple:
        if len(value) == 0:
            return ""
        return _optional_text_result(value[0])
    return _optional_text_result(value)


if __name__ == "__main__":
    raise SystemExit(main())
