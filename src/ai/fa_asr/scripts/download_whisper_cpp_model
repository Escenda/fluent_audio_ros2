#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
PACKAGE_DIR="$(cd -- "${SCRIPT_DIR}/.." >/dev/null 2>&1 && pwd -P)"
MODEL_ID="${1:-small-q5_1}"

SUPPORTED_MODELS="tiny tiny-q5_1 tiny-q8_0 tiny.en tiny.en-q5_1 tiny.en-q8_0 base base-q5_1 base-q8_0 base.en base.en-q5_1 base.en-q8_0 small small-q5_1 small-q8_0 small.en small.en-q5_1 small.en-q8_0 medium medium-q5_0 medium-q8_0 medium.en medium.en-q5_0 medium.en-q8_0 large-v1 large-v2 large-v2-q5_0 large-v2-q8_0 large-v3 large-v3-q5_0 large-v3-turbo large-v3-turbo-q5_0 large-v3-turbo-q8_0"

usage() {
  printf 'Usage: %s [model_id] [models_dir]\n' "$0" >&2
  printf 'Supported model ids: %s\n' "${SUPPORTED_MODELS}" >&2
}

sha1_for_model() {
  case "$1" in
    tiny) printf '%s\n' 'bd577a113a864445d4c299885e0cb97d4ba92b5f' ;;
    tiny-q5_1) printf '%s\n' '2827a03e495b1ed3048ef28a6a4620537db4ee51' ;;
    tiny-q8_0) printf '%s\n' '19e8118f6652a650569f5a949d962154e01571d9' ;;
    tiny.en) printf '%s\n' 'c78c86eb1a8faa21b369bcd33207cc90d64ae9df' ;;
    tiny.en-q5_1) printf '%s\n' '3fb92ec865cbbc769f08137f22470d6b66e071b6' ;;
    tiny.en-q8_0) printf '%s\n' '802d6668e7d411123e672abe4cb6c18f12306abb' ;;
    base) printf '%s\n' '465707469ff3a37a2b9b8d8f89f2f99de7299dac' ;;
    base-q5_1) printf '%s\n' 'a3733eda680ef76256db5fc5dd9de8629e62c5e7' ;;
    base-q8_0) printf '%s\n' '7bb89bb49ed6955013b166f1b6a6c04584a20fbe' ;;
    base.en) printf '%s\n' '137c40403d78fd54d454da0f9bd998f78703390c' ;;
    base.en-q5_1) printf '%s\n' 'd26d7ce5a1b6e57bea5d0431b9c20ae49423c94a' ;;
    base.en-q8_0) printf '%s\n' 'bb1574182e9b924452bf0cd1510ac034d323e948' ;;
    small) printf '%s\n' '55356645c2b361a969dfd0ef2c5a50d530afd8d5' ;;
    small-q5_1) printf '%s\n' '6fe57ddcfdd1c6b07cdcc73aaf620810ce5fc771' ;;
    small-q8_0) printf '%s\n' 'bcad8a2083f4e53d648d586b7dbc0cd673d8afad' ;;
    small.en) printf '%s\n' 'db8a495a91d927739e50b3fc1cc4c6b8f6c2d022' ;;
    small.en-q5_1) printf '%s\n' '20f54878d608f94e4a8ee3ae56016571d47cba34' ;;
    small.en-q8_0) printf '%s\n' '9d75ff4ccfa0a8217870d7405cf8cef0a5579852' ;;
    medium) printf '%s\n' 'fd9727b6e1217c2f614f9b698455c4ffd82463b4' ;;
    medium-q5_0) printf '%s\n' '7718d4c1ec62ca96998f058114db98236937490e' ;;
    medium-q8_0) printf '%s\n' 'e66645948aff4bebbec71b3485c576f3d63af5d6' ;;
    medium.en) printf '%s\n' '8c30f0e44ce9560643ebd10bbe50cd20eafd3723' ;;
    medium.en-q5_0) printf '%s\n' 'bb3b5281bddd61605d6fc76bc5b92d8f20284c3b' ;;
    medium.en-q8_0) printf '%s\n' 'b1cf48c12c807e14881f634fb7b6c6ca867f6b38' ;;
    large-v1) printf '%s\n' 'b1caaf735c4cc1429223d5a74f0f4d0b9b59a299' ;;
    large-v2) printf '%s\n' '0f4c8e34f21cf1a914c59d8b3ce882345ad349d6' ;;
    large-v2-q5_0) printf '%s\n' '00e39f2196344e901b3a2bd5814807a769bd1630' ;;
    large-v2-q8_0) printf '%s\n' 'da97d6ca8f8ffbeeb5fd147f79010eeea194ba38' ;;
    large-v3) printf '%s\n' 'ad82bf6a9043ceed055076d0fd39f5f186ff8062' ;;
    large-v3-q5_0) printf '%s\n' 'e6e2ed78495d403bef4b7cff42ef4aaadcfea8de' ;;
    large-v3-turbo) printf '%s\n' '4af2b29d7ec73d781377bfd1758ca957a807e941' ;;
    large-v3-turbo-q5_0) printf '%s\n' 'e050f7970618a659205450ad97eb95a18d69c9ee' ;;
    large-v3-turbo-q8_0) printf '%s\n' '01bf15bedffe9f39d65c1b6ff9b687ea91f59e0e' ;;
    *) return 1 ;;
  esac
}

url_for_model() {
  printf '%s\n' "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-$1.bin"
}

sha1_file() {
  sha1sum "$1" | awk '{print $1}'
}

download_file() {
  local url="$1"
  local output="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fL --output "$output" "$url"
    return
  fi
  if command -v wget >/dev/null 2>&1; then
    wget --output-document="$output" "$url"
    return
  fi
  printf 'curl or wget is required to download whisper.cpp model files\n' >&2
  return 1
}

default_models_dir() {
  if [[ -f "${PACKAGE_DIR}/package.xml" ]]; then
    printf '%s\n' "${PACKAGE_DIR}/models/whisper.cpp"
    return
  fi
  if [[ -z "${HOME:-}" ]]; then
    printf 'HOME is required when FLUENT_AUDIO_ASR_MODELS_DIR and models_dir are not set\n' >&2
    return 1
  fi
  printf '%s\n' "${HOME}/.cache/fluent_audio/fa_asr/models/whisper.cpp"
}

worker_path() {
  local worker="${SCRIPT_DIR}/whisper_cpp_worker"
  if [[ -f "${worker}" ]]; then
    printf '%s\n' "$(cd -- "$(dirname -- "${worker}")" >/dev/null 2>&1 && pwd -P)/$(basename -- "${worker}")"
  fi
}

print_environment() {
  printf 'FLUENT_AUDIO_ASR_MODEL_PATH=%s\n' "$1"
  local worker
  worker="$(worker_path)"
  if [[ -n "${worker}" ]]; then
    printf 'FLUENT_AUDIO_ASR_WORKER=%s\n' "${worker}"
  fi
}

EXPECTED_SHA1="$(sha1_for_model "${MODEL_ID}")" || {
  printf 'unsupported whisper.cpp model id: %s\n' "${MODEL_ID}" >&2
  usage
  exit 2
}

MODELS_DIR="${2:-${FLUENT_AUDIO_ASR_MODELS_DIR:-$(default_models_dir)}}"
mkdir -p "${MODELS_DIR}"
MODELS_DIR="$(cd -- "${MODELS_DIR}" >/dev/null 2>&1 && pwd -P)"
MODEL_PATH="${MODELS_DIR}/ggml-${MODEL_ID}.bin"

if [[ -f "${MODEL_PATH}" ]]; then
  ACTUAL_SHA1="$(sha1_file "${MODEL_PATH}")"
  if [[ "${ACTUAL_SHA1}" != "${EXPECTED_SHA1}" ]]; then
    printf 'existing model checksum mismatch: %s\n' "${MODEL_PATH}" >&2
    printf 'expected SHA-1: %s\nactual SHA-1:   %s\n' "${EXPECTED_SHA1}" "${ACTUAL_SHA1}" >&2
    exit 1
  fi
  print_environment "${MODEL_PATH}"
  exit 0
fi

TMP_MODEL="${MODEL_PATH}.tmp.$$"
cleanup() {
  if [[ -f "${TMP_MODEL}" ]]; then
    rm -f "${TMP_MODEL}"
  fi
}
trap cleanup EXIT

download_file "$(url_for_model "${MODEL_ID}")" "${TMP_MODEL}"
ACTUAL_SHA1="$(sha1_file "${TMP_MODEL}")"
if [[ "${ACTUAL_SHA1}" != "${EXPECTED_SHA1}" ]]; then
  printf 'downloaded model checksum mismatch for %s\n' "${MODEL_ID}" >&2
  printf 'expected SHA-1: %s\nactual SHA-1:   %s\n' "${EXPECTED_SHA1}" "${ACTUAL_SHA1}" >&2
  exit 1
fi

mv "${TMP_MODEL}" "${MODEL_PATH}"
print_environment "${MODEL_PATH}"
